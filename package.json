{
  "name": "warroom-scanner",
  "version": "0.1.0",
  "description": "War Room — ClamAV-powered threat scanner",
  "author": {
    "name": "Vince Stahl",
    "email": "pscstahl@gmail.com"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "clamscan": "^2.2.1",
    "d3-geo": "^3.1.1"
  },
  "build": {
    "appId": "io.threatop.warroom",
    "productName": "Threat-Op",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "clamav-bin/",
          "to": "clamav-bin",
          "filter": ["**/*"]
        }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "build/icons",
      "category": "Utility",
      "synopsis": "ClamAV-powered War Room threat scanner"
    }
  }
}