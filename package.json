{
  "name": "warroom-scanner",
  "version": "0.1.0",
  "description": "War Room — ClamAV-powered threat scanner",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "clamscan": "^2.2.1",
    "d3-geo": "^3.1.1"
  },
  "build": {
    "appId": "com.warroom.scanner",
    "productName": "War Room",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "clamav-bin/",
        "to": "clamav-bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
