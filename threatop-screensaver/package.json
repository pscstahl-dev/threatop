{
  "name": "threatop-screensaver",
  "version": "0.1.0",
  "description": "Threat-Op — War Room screensaver",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --screensaver",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.threatop.screensaver",
    "productName": "ThreatOp Screensaver",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "runAfterFinish": false
    },
    "extraResources": [
      {
        "from": "install-screensaver.bat",
        "to": "../Install Screensaver.bat"
      }
    ]
  }
}