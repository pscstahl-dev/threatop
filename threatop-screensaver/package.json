{
  "name": "threatop-screensaver",
  "version": "0.1.0",
  "description": "ThreatOp — War Room screensaver",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron . --screensaver",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.threatop.screensaver",
    "productName": "ThreatOp Screensaver",
    "win": {
      "target": "nsis",
      "fileAssociations": [
        {
          "ext": "scr",
          "name": "Screensaver"
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "runAfterFinish": false
    }
  }
}
